# apps/worker — env template (NO real values here; real secrets live in Doppler, project: worker).
# Copy to .env (gitignored) for local dev, or load via Doppler.

# --- Telegram (critical-path channel) ---
# BotFather token for the dev bot. Secret — never commit, never log.
TELEGRAM_BOT_TOKEN=
DEV_USER_ID=dev-user-0

# --- Crypto (DEV STAND-IN ONLY) ---
# 32-byte key as 64 hex chars or base64. If unset, an ephemeral per-process key is used
# (ciphertext won't survive a restart — fine for tests, never prod). Production uses the
# KMS-backed per-user DEK published by @workerchat/shared, not this.
WORKER_DEV_MASTER_KEY=

# --- Supabase (worker uses service_role; ONLY in the worker, never the browser) ---
# Pending Deliverable 1a (Track B applies schema + provisions creds). Left blank until then.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Logging ---
LOG_LEVEL=info

# --- Feature flags ---
# Unofficial WhatsApp (Baileys) stays OFF until the kill-test returns GO (docs/killtest/results.md).
ENABLE_WHATSAPP_UNOFFICIAL=false
