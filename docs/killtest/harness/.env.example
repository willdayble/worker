# Kill-test harness env template — COPY to .env and fill locally.
# .env is gitignored (repo root: .env.* ignored, **/.env.example allowed).
# NEVER put the real throwaway phone number or any secret in a committed file.

# --- Bridge selection -------------------------------------------------------
# waha  = WAHA self-host (recommended; data-sovereign; see docker-compose.yml)
# whapi = Whapi.cloud free Developer sandbox (hosted alternative)
# (Do NOT use GreenAPI for real data — community-flagged Russia-linked.)
BRIDGE=waha

# --- WAHA connection --------------------------------------------------------
# Where the bridge REST API listens. docker-compose maps it to localhost:3000.
WAHA_URL=http://localhost:3000
# Must match WAHA_API_KEY passed to the container. Generate a random value.
WAHA_API_KEY=

# --- Test subject -----------------------------------------------------------
# A LABEL ONLY for the throwaway number (e.g. "burner-au-01"). NEVER the real
# number. The number lives on the physical SIM/device, not in this repo.
KILLTEST_NUMBER_LABEL=burner-unlabeled

# --- Monitor cadence --------------------------------------------------------
# Human-paced experiment; polling every ~60s is plenty and avoids hammering WAHA.
POLL_INTERVAL_SECONDS=60
